{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "paths": {
      "@context/*": ["./src/context/*"],
      "@locales/*": ["./src/locales/*"],
      "@types/*": ["./src/types/*"],
      "@dtos/*": ["./src/dtos/*"],
      "@styles/*": ["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
      "@entities/*": ["./src/entities/*"],
      "@guards/*": ["./src/guards/*"],
      "@components/*": ["./src/components/*"],
      "@services/*": ["./src/services/*"],
      "@pages/*": ["./src/pages/*"],
    },
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
} 
